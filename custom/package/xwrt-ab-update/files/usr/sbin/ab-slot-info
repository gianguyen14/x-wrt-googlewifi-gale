#!/bin/bash
# =============================================================================
# ab-slot-info: Display current A/B partition slot information
# =============================================================================
set -euo pipefail

EMMC_DEV="/dev/mmcblk0"

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Detect active slot
detect_active_slot() {
    local root_dev
    root_dev=$(mount | grep "on / " | awk '{print $1}')

    case "$root_dev" in
        *p2|*ROOT-A*) echo "A" ;;
        *p4|*ROOT-B*) echo "B" ;;
        *)
            if grep -q "root=${EMMC_DEV}p2" /proc/cmdline 2>/dev/null; then
                echo "A"
            elif grep -q "root=${EMMC_DEV}p4" /proc/cmdline 2>/dev/null; then
                echo "B"
            else
                echo "?"
            fi
            ;;
    esac
}

active_slot=$(detect_active_slot)

echo -e "${CYAN}========================================${NC}"
echo -e "${CYAN} A/B Partition Status - Google WiFi Gale${NC}"
echo -e "${CYAN}========================================${NC}"
echo ""

# Show active slot
if [ "$active_slot" = "A" ]; then
    echo -e "  Active Slot:  ${GREEN}[A]${NC}  /  B"
elif [ "$active_slot" = "B" ]; then
    echo -e "  Active Slot:  A  /  ${GREEN}[B]${NC}"
else
    echo -e "  Active Slot:  ${YELLOW}Unknown${NC}"
fi
echo ""

# Show partition details
echo -e "${CYAN}--- Partition Layout ---${NC}"
echo ""

if command -v cgpt &>/dev/null; then
    cgpt show -q "$EMMC_DEV" 2>/dev/null || echo "  (cgpt info unavailable)"
else
    echo "  KERN-A:  ${EMMC_DEV}p1  $(blkid -o value -s TYPE ${EMMC_DEV}p1 2>/dev/null || echo 'N/A')"
    echo "  ROOT-A:  ${EMMC_DEV}p2  $(blkid -o value -s TYPE ${EMMC_DEV}p2 2>/dev/null || echo 'N/A')"
    echo "  KERN-B:  ${EMMC_DEV}p3  $(blkid -o value -s TYPE ${EMMC_DEV}p3 2>/dev/null || echo 'N/A')"
    echo "  ROOT-B:  ${EMMC_DEV}p4  $(blkid -o value -s TYPE ${EMMC_DEV}p4 2>/dev/null || echo 'N/A')"
    echo "  DATA:    ${EMMC_DEV}p5  $(blkid -o value -s TYPE ${EMMC_DEV}p5 2>/dev/null || echo 'N/A')"
fi

echo ""

# Show disk usage
echo -e "${CYAN}--- Disk Usage ---${NC}"
echo ""
df -h / /data 2>/dev/null | grep -v "^Filesystem" | while read -r line; do
    echo "  $line"
done

echo ""

# Show boot info
echo -e "${CYAN}--- Boot Info ---${NC}"
echo ""
echo "  Uptime:     $(uptime -p 2>/dev/null || uptime)"
echo "  Kernel:     $(uname -r)"
echo "  Root dev:   $(mount | grep "on / " | awk '{print $1}')"

# Check data partition
echo ""
if mountpoint -q /data 2>/dev/null; then
    echo -e "  Data Part:  ${GREEN}Mounted at /data${NC}"
else
    echo -e "  Data Part:  ${YELLOW}Not mounted${NC}"
fi

echo ""
echo -e "${CYAN}========================================${NC}"
